// Local.xcconfig
// ──────────────
// Per-developer overrides. This file is gitignored.
// Copy Local.xcconfig.example → Local.xcconfig and fill in your values.
//
// DEVELOPMENT_TEAM:
//   Your Apple Developer Team ID. Find it at https://developer.apple.com
//   under Membership → Team ID.
//
// PRODUCT_BUNDLE_IDENTIFIER:
//   A unique reverse-domain identifier for your build.
//   Change this if you want to install alongside another copy of the app.

DEVELOPMENT_TEAM = YOUR_TEAM_ID_HERE
PRODUCT_BUNDLE_IDENTIFIER = com.example.FruitcakeAi
